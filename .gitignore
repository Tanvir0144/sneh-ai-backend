# ================================
# Sneh Ai Backend - .gitignore
# TypeScript + Node.js (Express)
# ================================

# Node modules and dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build and compiled files
dist/
build/
tmp/
temp/

# TypeScript cache and output
*.tsbuildinfo
.tsbuildinfo
*.d.ts

# Environment variables (keep secrets private)
.env
.env.local
.env.development
.env.production
.env.test

# Logs and runtime data
logs/
*.log
*.pid
*.seed
*.pid.lock

# IDE / Editor directories
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# Test coverage & reports
coverage/
.nyc_output/
report.xml

# Misc
*.bak
*.tmp
*.swp

# Prevent accidental commits of sensitive data
# Especially API keys or local config
secret.json
config.local.json

# Lockfiles (optional: keep only one type)
package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ================================
# End of .gitignore
# ================================
